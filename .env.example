# Copy this file to .env and fill in your values
# cp .env.example .env

# Database
DATABASE_URL=sqlite:///./agent_platform.db

# Execution settings
MAX_EXECUTION_STEPS=5

# API Keys — each maps to a tenant
# Replace with your own secure random strings in production
API_KEY_TENANT_A=your-api-key-here
API_KEY_TENANT_B=your-api-key-here
API_KEY_TENANT_C=your-api-key-here

# External API Keys
GROQ_API_KEY=your-groq-api-key-here